# ==========================================================================
#  MLOps Training Environment — configuration
#  Copy to `.env` and change every CHANGE_ME_* value before installing.
#  `.env` is git-ignored and never committed.
# ==========================================================================

# ── Cluster ───────────────────────────────────────────────────────────────
CLUSTER_NAME=mlops-training
# Pin the Kubernetes node image for reproducibility
KIND_NODE_IMAGE=kindest/node:v1.34.0

# ── Component versions ─────────────────────────────────────────────────────
KFP_VERSION=2.16.1
TRAINING_OPERATOR_REF=v1.8.1

# ── Object storage (MinIO) ──────────────────────────────────────────────────
# Root/admin account (used by the notebook client, DVC remote, MLflow artifacts)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_root_password
# Dedicated account that Kubeflow Pipelines uses internally (kept separate from root)
MINIO_KFP_USER=minio
MINIO_KFP_PASSWORD=CHANGE_ME_minio_kfp_password

# ── JupyterLab ──────────────────────────────────────────────────────────────
JUPYTER_TOKEN=CHANGE_ME_jupyter_token
JUPYTER_PORT=8888

# ── Host tuning (Fedora) ────────────────────────────────────────────────────
# firewalld reloads flush kind's bridge FORWARD rules and break cross-node pod
# networking — disabling it lets Docker manage its own rules. Set to false only
# if you maintain the docker/kind firewalld zones yourself.
DISABLE_FIREWALLD=true
# Extend the root logical volume using free space in the volume group.
# A full deploy needs ~25 GB; default Fedora cloud images ship a small root LV.
EXTEND_ROOT_LV=true
MIN_ROOT_FREE_GB=25
